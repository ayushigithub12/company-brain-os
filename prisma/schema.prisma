generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  workspaces    Workspace[]
  sentInvites   Invite[]    @relation("SentInvites")
  receivedInvites Invite[]  @relation("ReceivedInvites")
  verifiedCards ProcessCard[] @relation("VerifiedCards")
  queryLogs     QueryLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workspace {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  ownerId     String

  owner      User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  connectors Connector[]
  documents  SourceDocument[]
  chunks     DocumentChunk[]
  cards      ProcessCard[]
  queryLogs  QueryLog[]
  sentInvites Invite[]      @relation("WorkspaceInvites")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

// Tracks who invited whom and which workspace they share access to
model Invite {
  id            String   @id @default(cuid())
  inviterId     String
  inviteeId     String
  workspaceId   String   // inviter's workspace the invitee gets access to
  
  seen          Boolean  @default(false) // for in-app notification
  
  inviter    User      @relation("SentInvites",     fields: [inviterId],   references: [id], onDelete: Cascade)
  invitee    User      @relation("ReceivedInvites",  fields: [inviteeId],   references: [id], onDelete: Cascade)
  workspace  Workspace @relation("WorkspaceInvites", fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([inviterId, inviteeId])
  @@index([inviteeId])
  @@index([workspaceId])
}

enum ConnectorType {
  NOTION
  GOOGLE_DRIVE
  SLACK
  GITHUB
}

enum ConnectorStatus {
  CONNECTED
  DISCONNECTED
  SYNCING
  ERROR
}

enum DocumentStatus {
  PENDING
  INDEXED
  FAILED
  STALE
}

enum CardStatus {
  DRAFT
  VERIFIED
  NEEDS_REVIEW
  ARCHIVED
}

model Connector {
  id          String          @id @default(cuid())
  workspaceId String
  type        ConnectorType
  name        String
  status      ConnectorStatus @default(DISCONNECTED)

  accessToken  String? @db.Text
  refreshToken String? @db.Text
  expiresAt    DateTime?

  externalWorkspaceId String?
  config              Json?

  lastSyncAt    DateTime?
  lastSyncError String?  @db.Text
  syncCount     Int      @default(0)

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documents SourceDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

model SourceDocument {
  id          String         @id @default(cuid())
  workspaceId String
  connectorId String?

  sourceId   String
  sourceType ConnectorType
  sourceUrl  String?

  title    String
  content  String @db.Text
  metadata Json?

  status          DocumentStatus @default(PENDING)
  lastIndexedAt   DateTime?
  sourceUpdatedAt DateTime?

  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connector    Connector?      @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  chunks       DocumentChunk[]
  processCards ProcessCard[]   @relation("ProcessCardSources")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, sourceType, sourceId])
  @@index([workspaceId])
}

model DocumentChunk {
  id          String @id @default(cuid())
  workspaceId String
  documentId  String

  content    String @db.Text
  chunkIndex Int
  tokenCount Int?
  heading    String?
  metadata   Json?
  vectorId   String? @unique

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  document  SourceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([documentId, chunkIndex])
  @@index([workspaceId])
  @@index([documentId])
}

model ProcessCard {
  id          String @id @default(cuid())
  workspaceId String

  name        String
  description String? @db.Text
  trigger     String? @db.Text
  steps       Json
  exceptions  Json?
  owners      String[] @default([])
  tags        String[] @default([])

  confidence   Float      @default(0)
  status       CardStatus @default(DRAFT)
  verifiedAt   DateTime?
  verifiedById String?

  workspace  Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  verifiedBy User?          @relation("VerifiedCards", fields: [verifiedById], references: [id], onDelete: SetNull)
  sources    SourceDocument[] @relation("ProcessCardSources")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([status])
}

model QueryLog {
  id          String @id @default(cuid())
  workspaceId String
  userId      String?

  query      String  @db.Text
  answer     String? @db.Text
  confidence Float?
  answered   Boolean @default(false)
  sources    Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([answered])
}
