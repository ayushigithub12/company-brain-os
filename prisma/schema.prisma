generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  ADMIN
  OWNER
  MEMBER
  VIEWER
}

enum ConnectorType {
  NOTION
  GOOGLE_DRIVE
  SLACK
  GITHUB
}

enum ConnectorStatus {
  CONNECTED
  DISCONNECTED
  SYNCING
  ERROR
}

enum DocumentStatus {
  PENDING
  INDEXED
  FAILED
  STALE
}

enum CardStatus {
  DRAFT
  VERIFIED
  NEEDS_REVIEW
  ARCHIVED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts      Account[]
  sessions      Session[]
  memberships   WorkspaceMember[]
  verifiedCards ProcessCard[] @relation("VerifiedCards")
  queryLogs     QueryLog[]
  sentInvitations     InvitationRecord[] @relation("SentInvitations")
  receivedInvitations InvitationRecord[] @relation("ReceivedInvitations")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  members    WorkspaceMember[]
  connectors Connector[]
  documents  SourceDocument[]
  chunks     DocumentChunk[]
  cards      ProcessCard[]
  queryLogs  QueryLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  workspaceId String
  userId      String
  role        MemberRole @default(OWNER)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, userId])
}

model InvitationRecord {
  id          String   @id @default(cuid())
  workspaceId String
  inviterId   String
  inviteeId   String
  role        String

  inviter User @relation("SentInvitations",    fields: [inviterId], references: [id], onDelete: Cascade)
  invitee User @relation("ReceivedInvitations", fields: [inviteeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([workspaceId, inviterId, inviteeId])
  @@index([workspaceId])
  @@index([inviteeId])
}

model Connector {
  id          String          @id @default(cuid())
  workspaceId String
  type        ConnectorType
  name        String
  status      ConnectorStatus @default(DISCONNECTED)

  accessToken  String? @db.Text
  refreshToken String? @db.Text
  expiresAt    DateTime?

  externalWorkspaceId String?
  config              Json?

  lastSyncAt    DateTime?
  lastSyncError String?  @db.Text
  syncCount     Int      @default(0)

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documents SourceDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([type])
}

model SourceDocument {
  id          String         @id @default(cuid())
  workspaceId String
  connectorId String?

  sourceId   String
  sourceType ConnectorType
  sourceUrl  String?

  title    String
  content  String @db.Text
  metadata Json?

  status        DocumentStatus @default(PENDING)
  lastIndexedAt DateTime?
  sourceUpdatedAt DateTime?

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connector Connector?      @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  chunks    DocumentChunk[]

  processCards ProcessCard[] @relation("ProcessCardSources")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, sourceType, sourceId])
  @@index([workspaceId])
  @@index([sourceType])
}

model DocumentChunk {
  id          String @id @default(cuid())
  workspaceId String
  documentId  String

  content    String @db.Text
  chunkIndex Int
  tokenCount Int?
  heading    String?
  metadata   Json?

  vectorId String? @unique

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  document  SourceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([documentId, chunkIndex])
  @@index([workspaceId])
  @@index([documentId])
}

model ProcessCard {
  id          String @id @default(cuid())
  workspaceId String

  name        String
  description String? @db.Text
  trigger     String? @db.Text

  steps      Json
  exceptions Json?
  owners     String[] @default([])
  tags       String[] @default([])

  confidence Float      @default(0)
  status     CardStatus @default(DRAFT)

  verifiedAt   DateTime?
  verifiedById String?

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  verifiedBy User?     @relation("VerifiedCards", fields: [verifiedById], references: [id], onDelete: SetNull)

  sources SourceDocument[] @relation("ProcessCardSources")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([status])
}

model QueryLog {
  id          String @id @default(cuid())
  workspaceId String
  userId      String?

  query      String @db.Text
  answer     String? @db.Text
  confidence Float?
  answered   Boolean @default(false)

  sources Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([answered])
}
